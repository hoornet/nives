    "express": "^5.2.1",
    "multer": "^2.0.2",
    "openai": "^6.42.0",
    "undici": "^8.4.1",
    "uuid": "^14.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.21",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
