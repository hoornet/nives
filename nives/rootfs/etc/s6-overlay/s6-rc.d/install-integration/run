#!/command/with-contenv bash
# Auto-install the Home Mind HA integration (custom component)
# so users don't need HACS or manual file copying.

SOURCE="/opt/home_mind_integration"
TARGET="/config/custom_components/home_mind"

if [ ! -d /config ]; then
    echo "[integration] /config not mounted — skipping integration install"
    exit 0
fi

# Check if files need updating by comparing manifest versions
NEEDS_UPDATE=false
if [ ! -d "$TARGET" ]; then
    NEEDS_UPDATE=true
    echo "[integration] Installing Home Mind integration..."
elif [ -f "$SOURCE/manifest.json" ] && [ -f "$TARGET/manifest.json" ]; then
    SOURCE_VER=$(jq -r '.version' "$SOURCE/manifest.json" 2>/dev/null || echo "")
    TARGET_VER=$(jq -r '.version' "$TARGET/manifest.json" 2>/dev/null || echo "")
    if [ "$SOURCE_VER" != "$TARGET_VER" ]; then
        NEEDS_UPDATE=true
        echo "[integration] Updating Home Mind integration (${TARGET_VER} → ${SOURCE_VER})..."
    fi
fi

if [ "$NEEDS_UPDATE" = "true" ]; then
    mkdir -p "$TARGET"
    cp -f "$SOURCE"/*.py "$TARGET/"
    cp -f "$SOURCE"/*.json "$TARGET/"
    echo "[integration] Home Mind integration installed at $TARGET"

    # Restart HA Core so it picks up the new integration files and processes discovery.
    # This only runs on first install or after an integration update.
    if [ -n "$SUPERVISOR_TOKEN" ]; then
        echo "[integration] Restarting HA Core to load updated integration..."
        curl -s -X POST \
            -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
            http://supervisor/core/restart || true
        echo "[integration] HA Core restart triggered"
    else
        echo "[integration] No SUPERVISOR_TOKEN — skipping HA Core restart"
    fi
else
    echo "[integration] Home Mind integration is up to date"
fi
